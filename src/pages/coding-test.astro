---
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { url } from "../utils/url-utils";

const problems = await getCollection("problems");
// Sort by solved date, newest first
problems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// --- Contribution heatmap (binary: recorded a problem that day or not) ---
const solvedSet = new Set(
	problems.map((p) => p.data.date.toISOString().slice(0, 10)),
);

const monthNames = ["1월", "2월", "3월", "4월", "5월", "6월", "7월", "8월", "9월", "10월", "11월", "12월"];
const weekdayLabels = ["", "월", "", "수", "", "금", ""]; // Sun..Sat, label Mon/Wed/Fri (left axis)

interface HeatCell {
	key: string;
	inYear: boolean;
	filled: boolean;
}
interface HeatWeek {
	cells: HeatCell[]; // 7 cells, Sun..Sat (vertical)
	monthLabel: string; // shown above the column where a new month begins
}

// Build a full calendar year as week-columns (horizontal, GitHub-style).
function buildYear(year: number): HeatWeek[] {
	const dec31 = new Date(Date.UTC(year, 11, 31));
	const start = new Date(Date.UTC(year, 0, 1));
	start.setUTCDate(start.getUTCDate() - start.getUTCDay()); // snap back to Sunday
	const weeks: HeatWeek[] = [];
	let lastMonth = -1;
	const weekStart = new Date(start);
	while (weekStart <= dec31) {
		const cells: HeatCell[] = [];
		for (let i = 0; i < 7; i++) {
			const day = new Date(weekStart);
			day.setUTCDate(day.getUTCDate() + i);
			const inYear = day.getUTCFullYear() === year;
			const key = day.toISOString().slice(0, 10);
			cells.push({ key, inYear, filled: inYear && solvedSet.has(key) });
		}
		// Month label above the first column of each new month
		const firstInYear = cells.find((c) => c.inYear);
		let monthLabel = "";
		if (firstInYear) {
			const m = Number(firstInYear.key.slice(5, 7)) - 1;
			if (m !== lastMonth) {
				monthLabel = monthNames[m];
				lastMonth = m;
			}
		}
		weeks.push({ cells, monthLabel });
		weekStart.setUTCDate(weekStart.getUTCDate() + 7);
	}
	return weeks;
}

const currentYear = new Date().getUTCFullYear();
const years = Array.from(
	new Set([...problems.map((p) => p.data.date.getUTCFullYear()), currentYear]),
).sort((a, b) => a - b);
const defaultYear = years.includes(currentYear) ? currentYear : years[years.length - 1];

const yearData = years.map((y) => ({
	year: y,
	weeks: buildYear(y),
	count: [...solvedSet].filter((k) => Number(k.slice(0, 4)) === y).length,
}));
---
<MainGridLayout title="코딩테스트" description="백준·프로그래머스 등에서 푼 문제 기록">
    <div class="flex flex-col gap-4">
        <div class="card-base z-10 px-6 md:px-9 py-6">
            <h1 class="text-2xl md:text-3xl font-bold text-90 mb-1">코딩테스트</h1>
            <p class="text-50">백준·프로그래머스 등에서 푼 문제를 사이트·언어·알고리즘별로 기록합니다.</p>
            <span class="text-30 text-sm">총 {problems.length}문제</span>
        </div>

        <!-- Contribution heatmap (horizontal, year tabs) -->
        <div class="card-base z-10 px-6 md:px-9 py-6" data-ct-heatmap>
            <div class="flex items-center justify-between gap-2 mb-4 flex-wrap">
                <h2 class="text-lg font-bold text-90">문제 풀이 기록</h2>
                <div class="flex gap-1">
                    {years.map((y) => (
                        <button type="button" data-ct-year={String(y)}
                            class:list={["ct-tab px-3 py-1 rounded-lg text-sm font-medium", y === defaultYear && "ct-active"]}>
                            {y}
                        </button>
                    ))}
                </div>
            </div>

            {yearData.map(({ year, weeks, count }) => (
                <div data-ct-panel={String(year)} class:list={["ct-panel", year === defaultYear && "ct-active"]}>
                    <!-- Month labels (top axis) — fills width, no horizontal scroll -->
                    <div class="flex gap-[2px] mb-[2px]">
                        <div class="shrink-0 pr-1 text-[9px] leading-none invisible select-none">금</div>
                        {weeks.map((w) => (
                            <div class="flex-1 min-w-0 relative h-3">
                                {w.monthLabel && (
                                    <span class="absolute left-0 bottom-0 text-[9px] leading-none text-30 whitespace-nowrap">{w.monthLabel}</span>
                                )}
                            </div>
                        ))}
                    </div>
                    <!-- Weekday labels (left axis) + fluid week columns -->
                    <div class="flex gap-[2px] items-stretch">
                        <div class="shrink-0 flex flex-col gap-[2px] pr-1">
                            {weekdayLabels.map((wd) => (
                                <div class="flex-1 flex items-center justify-end text-[9px] leading-none text-30">{wd}</div>
                            ))}
                        </div>
                        {weeks.map((w) => (
                            <div class="flex-1 min-w-0 flex flex-col gap-[2px]">
                                {w.cells.map((c) => (
                                    c.inYear ? (
                                        <div
                                            class={`aspect-square rounded-[1px] ${c.filled ? "bg-[var(--primary)]" : "bg-[var(--btn-regular-bg)]"}`}
                                            title={c.filled ? `${c.key} · 기록함` : c.key}
                                        ></div>
                                    ) : (
                                        <div class="aspect-square"></div>
                                    )
                                ))}
                            </div>
                        ))}
                    </div>
                    <div class="flex items-center gap-2 mt-3 text-30 text-xs flex-wrap">
                        <span>기록 없음</span>
                        <div class="w-3 h-3 rounded-[2px] bg-[var(--btn-regular-bg)]"></div>
                        <div class="w-3 h-3 rounded-[2px] bg-[var(--primary)]"></div>
                        <span>기록함</span>
                        <span class="ml-1">· {year}년 {count}일 기록</span>
                    </div>
                </div>
            ))}
        </div>

        {problems.length > 0 && (
            <section class="card-base z-10 px-6 md:px-9 py-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    {problems.map((p) => (
                        <a href={url(`/coding-test/${p.slug}/`)} aria-label={p.data.title}
                           class="group flex flex-col gap-2 rounded-xl px-5 py-4 bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:scale-[0.99] transition">
                            <div class="flex items-start justify-between gap-3">
                                <h2 class="font-bold leading-snug min-w-0">
                                    <span class="text-[var(--primary)]">[{p.data.site}]</span>
                                    <span class="text-90 group-hover:text-[var(--primary)] transition">{p.data.title}</span>
                                </h2>
                                <time class="text-30 text-xs whitespace-nowrap shrink-0 mt-1">
                                    {formatDateToYYYYMMDD(p.data.date)}
                                </time>
                            </div>
                            {p.data.source && (
                                <span class="text-50 text-sm -mt-1">{p.data.source}</span>
                            )}
                            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-30 text-sm">
                                {p.data.level && <span>#{p.data.level}</span>}
                                {p.data.languages.map((lang) => <span>#{lang}</span>)}
                                {p.data.algorithms.map((algo) => <span>#{algo}</span>)}
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}

        {problems.length === 0 && (
            <div class="card-base z-10 px-9 py-12 text-center text-50">
                아직 기록된 문제가 없습니다.
            </div>
        )}
    </div>
</MainGridLayout>

<style>
    .ct-tab {
        background: var(--btn-regular-bg);
        transition: background 0.2s, color 0.2s;
    }
    .ct-tab:hover {
        background: var(--btn-regular-bg-hover);
    }
    .ct-tab.ct-active {
        background: var(--primary);
        color: #fff;
    }
    .ct-panel {
        display: none;
    }
    .ct-panel.ct-active {
        display: block;
    }
</style>

<script>
    // Year-tab switching for the contribution heatmap.
    // Delegated on document so it survives swup page transitions.
    document.addEventListener("click", (e) => {
        const t = e.target;
        if (!(t instanceof Element)) return;
        const btn = t.closest("[data-ct-year]");
        if (!btn) return;
        const root = btn.closest("[data-ct-heatmap]");
        if (!root) return;
        const year = btn.getAttribute("data-ct-year");
        root.querySelectorAll("[data-ct-year]").forEach((b) =>
            b.classList.toggle("ct-active", b.getAttribute("data-ct-year") === year),
        );
        root.querySelectorAll("[data-ct-panel]").forEach((p) =>
            p.classList.toggle("ct-active", p.getAttribute("data-ct-panel") === year),
        );
    });
</script>
