---
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";

const problems = await getCollection("problems");
// Sort by solved date, newest first
problems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by year-month
interface MonthGroup {
	year: number;
	month: number;
	items: typeof problems;
}
const groupsMap = new Map<string, MonthGroup>();
for (const p of problems) {
	const d = p.data.date;
	const year = d.getUTCFullYear();
	const month = d.getUTCMonth() + 1;
	const key = `${year}-${month}`;
	if (!groupsMap.has(key)) groupsMap.set(key, { year, month, items: [] });
	groupsMap.get(key)!.items.push(p);
}
const groups = Array.from(groupsMap.values()).sort(
	(a, b) => b.year - a.year || b.month - a.month,
);
---
<MainGridLayout title="코딩테스트" description="백준·프로그래머스 등에서 푼 문제 기록">
    <div class="flex flex-col gap-4">
        <div class="card-base z-10 px-6 md:px-9 py-6">
            <h1 class="text-2xl md:text-3xl font-bold text-90 mb-1">코딩테스트</h1>
            <p class="text-50">백준·프로그래머스 등에서 푼 문제를 사이트·언어·알고리즘별로 기록합니다.</p>
            <span class="text-30 text-sm">총 {problems.length}문제</span>
        </div>

        {groups.map((group) => (
            <section class="card-base z-10 px-6 md:px-9 py-6">
                <div class="flex items-baseline gap-2 mb-5">
                    <span class="text-xl font-bold text-90">{group.year}년 {group.month}월</span>
                    <span class="text-30 text-sm">{group.items.length}</span>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    {group.items.map((p) => {
                        const Wrapper = p.data.url ? "a" : "div";
                        const wrapperProps = p.data.url
                            ? { href: p.data.url, target: "_blank", rel: "noopener noreferrer" }
                            : {};
                        return (
                            <Wrapper {...wrapperProps}
                                class={`flex flex-col gap-2 rounded-xl px-5 py-4 bg-[var(--btn-regular-bg)] transition ${p.data.url ? "hover:bg-[var(--btn-regular-bg-hover)] active:scale-[0.99] group" : ""}`}>
                                <div class="flex items-start justify-between gap-3">
                                    <div class="flex flex-col gap-0.5 min-w-0">
                                        <h2 class="font-bold text-90 leading-snug group-hover:text-[var(--primary)] transition">
                                            {p.data.title}
                                        </h2>
                                        {p.data.source && (
                                            <span class="text-50 text-sm truncate">{p.data.source}</span>
                                        )}
                                    </div>
                                    <time class="text-30 text-xs whitespace-nowrap shrink-0 mt-0.5">
                                        {formatDateToYYYYMMDD(p.data.date)}
                                    </time>
                                </div>

                                <div class="flex flex-wrap items-center gap-1.5">
                                    <!-- Site chip (accent) -->
                                    <span class="text-xs font-medium px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)]">
                                        {p.data.site}
                                    </span>
                                    {p.data.level && (
                                        <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg-active)] text-70">
                                            #{p.data.level}
                                        </span>
                                    )}
                                    {p.data.languages.map((lang) => (
                                        <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg-active)] text-70">
                                            #{lang}
                                        </span>
                                    ))}
                                    {p.data.algorithms.map((algo) => (
                                        <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg-active)] text-70">
                                            #{algo}
                                        </span>
                                    ))}
                                </div>
                            </Wrapper>
                        );
                    })}
                </div>
            </section>
        ))}

        {problems.length === 0 && (
            <div class="card-base z-10 px-9 py-12 text-center text-50">
                아직 기록된 문제가 없습니다.
            </div>
        )}
    </div>
</MainGridLayout>
