---
import { getCollection } from "astro:content";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
import { url } from "../utils/url-utils";

const problems = await getCollection("problems");
// Sort by solved date, newest first
problems.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<MainGridLayout title="코딩테스트" description="백준·프로그래머스 등에서 푼 문제 기록">
    <div class="flex flex-col gap-4">
        <div class="card-base z-10 px-6 md:px-9 py-6">
            <h1 class="text-2xl md:text-3xl font-bold text-90 mb-1">코딩테스트</h1>
            <p class="text-50">백준·프로그래머스 등에서 푼 문제를 사이트·언어·알고리즘별로 기록합니다.</p>
            <span class="text-30 text-sm">총 {problems.length}문제</span>
        </div>

        {problems.length > 0 && (
            <section class="card-base z-10 px-6 md:px-9 py-6">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    {problems.map((p) => (
                        <a href={url(`/coding-test/${p.slug}/`)} aria-label={p.data.title}
                           class="group flex flex-col gap-2 rounded-xl px-5 py-4 bg-[var(--btn-regular-bg)] hover:bg-[var(--btn-regular-bg-hover)] active:scale-[0.99] transition">
                            <!-- Line 1: [site] title ............ date -->
                            <div class="flex items-start justify-between gap-3">
                                <h2 class="font-bold leading-snug min-w-0">
                                    <span class="text-[var(--primary)]">[{p.data.site}]</span>
                                    <span class="text-90 group-hover:text-[var(--primary)] transition">{p.data.title}</span>
                                </h2>
                                <time class="text-30 text-xs whitespace-nowrap shrink-0 mt-1">
                                    {formatDateToYYYYMMDD(p.data.date)}
                                </time>
                            </div>

                            <!-- Line 2: source -->
                            {p.data.source && (
                                <span class="text-50 text-sm -mt-1">{p.data.source}</span>
                            )}

                            <!-- Line 3: tags -->
                            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-30 text-sm">
                                {p.data.level && <span>#{p.data.level}</span>}
                                {p.data.languages.map((lang) => <span>#{lang}</span>)}
                                {p.data.algorithms.map((algo) => <span>#{algo}</span>)}
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}

        {problems.length === 0 && (
            <div class="card-base z-10 px-9 py-12 text-center text-50">
                아직 기록된 문제가 없습니다.
            </div>
        )}
    </div>
</MainGridLayout>
